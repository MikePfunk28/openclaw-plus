# ============================================
# OpenClaw Plus Environment Configuration
# ============================================

# ------------------
# AI Provider Keys
# ------------------

# Anthropic (Claude) - Required for Claude models
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI - Required for GPT models
# OPENAI_API_KEY=sk-your-key-here

# Google Gemini - Required for Gemini models
# GEMINI_API_KEY=your-gemini-key-here

# DeepSeek - Optional
# DEEPSEEK_API_KEY=your-deepseek-key

# XAI (Grok) - Optional
# XAI_API_KEY=your-xai-key

# ------------------
# Authentication
# ------------------

# JWT secret for token signing (generate a random string)
OPENCLAW_JWT_SECRET=your-jwt-secret-change-in-production

# Owner token for admin access
OPENCLAW_OWNER_TOKEN=your-owner-token-change-in-production

# WebSocket token
OPENCLAW_WS_TOKEN=your-ws-token-change-in-production

# Inbound webhook token
OPENCLAW_INBOUND_TOKEN=your-inbound-token-change-in-production

# ------------------
# OAuth Providers
# ------------------

# Anthropic OAuth (for subscription access)
# ANTHROPIC_CLIENT_ID=your-client-id
# ANTHROPIC_CLIENT_SECRET=your-client-secret

# OpenAI OAuth
# OPENAI_CLIENT_ID=your-client-id
# OPENAI_CLIENT_SECRET=your-client-secret

# Google OAuth (for Gemini subscription access)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# ------------------
# Chat Platforms
# ------------------

# Telegram Bot Token
# TELEGRAM_BOT_TOKEN=your-telegram-token

# Discord Bot Token
# DISCORD_BOT_TOKEN=your-discord-token

# ------------------
# Security Settings
# ------------------

# Allow dangerous shell commands (default: false)
OPENCLAW_ALLOW_DANGEROUS_SHELL=false

# Enable automation supervisor (default: false)
OPENCLAW_AUTOMATION_ENABLED=false

# ------------------
# Server Settings
# ------------------

# Server port (default: 8787)
# PORT=8787

# Log level (debug, info, warn, error)
# LOG_LEVEL=info
